# =============================================================================
# MCP HUB CONFIGURATION TEMPLATE
# Copy this file to .env and fill in your actual values
# =============================================================================

# =============================================================================
# MODEL & EMBEDDINGS
# =============================================================================
MODEL_PROVIDER=openai
MODEL_TEMPERATURE=0.4
MAX_TOKENS=1500


# =============================================================================
# OPENAI
# =============================================================================
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDINGS_MODEL=text-embedding-3-small


# =============================================================================
# GROQ
# =============================================================================
GROQ_API_KEY=gsk_your-groq-api-key-here
GROQ_MODEL=openai/gpt-oss-120b


# =============================================================================
# OPENROUTER
# =============================================================================
OPEN_ROUTER_API_KEY=sk-or-v1_your-openrouter-api-key-here
OPEN_ROUTER_CHAT_MODEL=baidu/ernie-4.5-21b-a3b
OPEN_ROUTER_EMBEDDINGS_MODEL=openai/text-embedding-3-small
OPEN_ROUTER_BASE_URL=https://api.openrouter.ai


# =============================================================================
# GOOGLE GEMINI
# =============================================================================
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_MODEL=gemini-2.5-flash


# =============================================================================
# REDIS
# =============================================================================
REDIS_URL=redis://:your-redis-password@valkey:6379/0


# =============================================================================
# PAGE INDEX
# =============================================================================
PAGE_INDEX_API_KEY=your-pageindex-api-key-here


# =============================================================================
# EMAIL (SMTP)
# =============================================================================
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-password-here


# =============================================================================
# User Details
# =============================================================================
MY_EMAIL=your-email@example.com


# =============================================================================
# WEATHER API
# =============================================================================
OPENWEATHERMAP_API_KEY=your-openweathermap-api-key-here


# =============================================================================
# FASTAPI SERVER
# =============================================================================
ENV=local
DEBUG=True


# =============================================================================
# FASTMCP
# =============================================================================
FASTMCP_LOG_LEVEL=INFO
FASTMCP_PORT=8000
FASTMCP2_PORT=8005
FASTMCP_HOST=0.0.0.0
FASTMCP_STREAMABLE_HTTP_PATH=/mcp


# =============================================================================
# DATASTORE
# =============================================================================
DATASTORE_DIR=./datastore
INTERNAL_DIR=./datastore/internal
SQLITE_DB_PATH=./datastore/internal/sqlite3.db
DOWNLOADS_DIR=./datastore/downloads